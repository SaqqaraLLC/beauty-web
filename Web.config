<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="httpPlatformHandler" path="*" verb="*"
           modules="httpPlatformHandlerV2"
           resourceType="Unspecified"
           requireAccess="Script" />
    </handlers>
    <httpPlatform
      processPath="node"
      arguments="server.js"
      stdoutLogEnabled="true"
      stdoutLogFile="%home%\LogFiles\Application\node.log"
      startupTimeLimit="60"
      requestTimeout="00:02:00">
      <environmentVariables>
        <environmentVariable name="PORT"                    value="%HTTP_PLATFORM_PORT%" />
        <environmentVariable name="NODE_ENV"                value="production" />
        <environmentVariable name="NEXT_TELEMETRY_DISABLED" value="1" />
        <environmentVariable name="NEXT_PUBLIC_API_URL"     value="https://api.saqqarallc.com" />
      </environmentVariables>
    </httpPlatform>
  </system.webServer>
</configuration>
